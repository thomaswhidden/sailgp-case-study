---
import '../styles/global.css';
import { url } from '../utils/url';

interface Props {
  title?: string;
}

const { title } = Astro.props;
const pageTitle = title ? `${title} — SailGP Case Study` : 'SailGP Case Study';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={url('/favicon.svg')} />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,700&family=JetBrains+Mono:wght@400;500;700&family=Space+Grotesk:wght@300;400;500;600;700&family=Instrument+Serif&display=swap"
      rel="stylesheet"
    />
    <link href={url('/pagefind/pagefind-ui.css')} rel="stylesheet" />
  </head>
  <body>
    <slot />
    <script src={url('/pagefind/pagefind-ui.js')} is:inline></script>
  </body>
</html>
