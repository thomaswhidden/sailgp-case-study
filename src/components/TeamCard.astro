---
import { url } from '../utils/url';
interface Props {
  name: string;
  nation: string;
  current_owner: string;
  current_valuation_usd?: number;
  latest_valuation_date?: string;
  championships: number;
  title_sponsor?: string;
  driver?: string;
  slug: string;
  status: string;
  color?: string;
  imageSrc?: string;
  imageAlt?: string;
}

const {
  name, nation, current_owner, current_valuation_usd,
  championships, title_sponsor, driver, slug,
  color = 'var(--mute)', imageSrc, imageAlt,
} = Astro.props;

function formatVal(v?: number): string {
  if (!v) return '—';
  return `$${Math.round(v / 1_000_000)}M`;
}

const code = nation.slice(0, 3).toUpperCase();
---

<a
  href={url(`/teams/${slug}`)}
  class="block card-hover"
  style="background:var(--bone-2);text-decoration:none;overflow:hidden;"
>
  <!-- Image strip -->
  {imageSrc && (
    <div style="height:140px;overflow:hidden;position:relative;">
      <img
        src={imageSrc}
        alt={imageAlt ?? name}
        loading="lazy"
        style="width:100%;height:100%;object-fit:cover;object-position:center 35%;transition:transform 400ms ease;"
        class="team-card-img"
      />
      <div style="position:absolute;inset:0;background:linear-gradient(to bottom, transparent 50%, rgba(11,31,38,0.35) 100%);"></div>
      <!-- color band over image -->
      <div style={`position:absolute;top:0;left:0;bottom:0;width:5px;background:${color};`}></div>
    </div>
  )}

  <div style="padding:18px 20px;">
    <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:10px;">
      <div style="display:flex;align-items:center;gap:8px;">
        {!imageSrc && <div style={`width:6px;height:24px;background:${color};flex-shrink:0;`}></div>}
        <div>
          <div class="type-eyebrow" style="color:var(--mute);">{code}</div>
          <div style="font-family:var(--font-display);font-size:19px;line-height:1;letter-spacing:-0.02em;margin-top:3px;color:var(--ink);">{name}</div>
        </div>
      </div>
      {current_valuation_usd && (
        <div style="font-family:var(--font-display);font-size:24px;color:var(--sun);line-height:1;letter-spacing:-0.02em;">{formatVal(current_valuation_usd)}</div>
      )}
    </div>

    <div style="height:1px;background:rgba(11,31,38,0.1);margin:10px 0;"></div>

    <div class="type-eyebrow mb-1" style="color:var(--mute);">Owners</div>
    <div style="font-family:var(--font-serif);font-size:13px;line-height:1.4;color:var(--ink);">{current_owner}</div>

    <div style="display:flex;justify-content:space-between;margin-top:12px;flex-wrap:wrap;gap:8px;">
      {title_sponsor && (
        <div>
          <div class="type-eyebrow mb-1" style="color:var(--mute);">Sponsor</div>
          <div style="font-family:var(--font-serif);font-size:12px;color:var(--ink);">{title_sponsor}</div>
        </div>
      )}
      {driver && (
        <div>
          <div class="type-eyebrow mb-1" style="color:var(--mute);">Skipper</div>
          <div style="font-family:var(--font-serif);font-size:12px;color:var(--ink);">{driver}</div>
        </div>
      )}
      <div style="text-align:right;margin-left:auto;">
        <div class="type-eyebrow mb-1" style="color:var(--mute);">Titles</div>
        <div style={`font-family:var(--font-serif);font-size:13px;color:${championships ? 'var(--sun)' : 'var(--mute)'};`}>
          {championships ? '★'.repeat(championships) : '—'}
        </div>
      </div>
    </div>
  </div>
</a>

<style>
  .team-card-img { transition: transform 400ms ease; }
  a:hover .team-card-img { transform: scale(1.04); }
</style>
