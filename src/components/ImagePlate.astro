---
interface Props {
  src?: string;
  alt: string;
  height?: number | string;
  caption?: string;
  accent?: string;
  objectPosition?: string;
}
const {
  src,
  alt,
  height = 320,
  caption,
  accent = 'var(--ink-2)',
  objectPosition = 'center 30%',
} = Astro.props;
const h = typeof height === 'number' ? `${height}px` : height;
const gradId = `plate-${Math.random().toString(36).slice(2,7)}`;
---

{src ? (
  <div style={`height:${h};position:relative;overflow:hidden;background:${accent};`}>
    <img
      src={src}
      alt={alt}
      loading="lazy"
      class="parallax-plate"
      style={`width:100%;height:115%;object-fit:cover;object-position:${objectPosition};`}
    />
    {caption && (
      <div class="type-eyebrow" style="position:absolute;bottom:14px;left:18px;color:rgba(242,235,221,0.8);">
        {caption}
      </div>
    )}
  </div>
) : (
  <div role="presentation" style={`height:${h};background:${accent};position:relative;overflow:hidden;`}>
    <!-- Horizontal striations -->
    <div style="position:absolute;inset:0;background-image:repeating-linear-gradient(180deg,rgba(242,235,221,0.04) 0 1px,transparent 1px 8px);"></div>
    <!-- Wake SVG -->
    <svg viewBox="0 0 800 400" preserveAspectRatio="none" style="position:absolute;inset:0;width:100%;height:100%;">
      <defs>
        <linearGradient id={gradId} x1="0" x2="1" y1="1" y2="0">
          <stop offset="0%" stop-color="var(--bone)" stop-opacity="0" />
          <stop offset="100%" stop-color="var(--sun)" stop-opacity="0.5" />
        </linearGradient>
      </defs>
      <path d="M0,360 Q200,340 400,270 T800,180" stroke={`url(#${gradId})`} stroke-width="2" fill="none" opacity="0.9" />
      <path d="M0,380 Q220,350 420,280 T800,200" stroke="var(--bone)" stroke-width="1" fill="none" opacity="0.3" />
    </svg>
    <!-- Sun disc -->
    <div style="position:absolute;top:22%;right:14%;width:100px;height:100px;border-radius:50%;background:radial-gradient(circle at 30% 30%,var(--sun-2),var(--sun) 60%,var(--ink) 100%);opacity:0.85;"></div>
    {caption && (
      <div class="type-eyebrow" style="position:absolute;bottom:14px;left:18px;color:rgba(242,235,221,0.8);">
        ◷ Image plate · {caption}
      </div>
    )}
  </div>
)}
