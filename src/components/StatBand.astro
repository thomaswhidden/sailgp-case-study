---
interface Stat {
  value: string;
  label: string;
  source?: string;
  sourceUrl?: string;
}
interface Props {
  stats: Stat[];
  label?: string;
}
const { stats, label = 'The case in six numbers' } = Astro.props;
---

<div class="px-6 md:px-10 lg:px-16 py-14 md:py-20">
  {label && <div class="eyebrow-marker mb-6">{label}</div>}
  <div
    class="grid"
    style={`grid-template-columns:repeat(${stats.length},1fr);border-top:1px solid var(--border-ink);border-bottom:1px solid var(--border-ink);`}
  >
    {stats.map((s, i) => (
      <div
        class="py-7 px-5"
        style={i < stats.length - 1 ? 'border-right:1px solid var(--border-ink);' : ''}
      >
        <div
          class="stat-num type-4"
          data-target={s.value}
          style="color:var(--ink);"
        >
          {s.value}
        </div>
        <div class="type-eyebrow mt-3" style="color:var(--mute);">{s.label}</div>
        {s.source && (
          s.sourceUrl
            ? <a href={s.sourceUrl} target="_blank" rel="noopener" class="type-eyebrow mt-1 block" style="color:rgba(11,31,38,0.35);font-size:8.5px;letter-spacing:0.1em;text-decoration:none;hover:color:var(--sun);">↗ {s.source}</a>
            : <span class="type-eyebrow mt-1 block" style="color:rgba(11,31,38,0.35);font-size:8.5px;letter-spacing:0.1em;">{s.source}</span>
        )}
      </div>
    ))}
  </div>
</div>

<script>
  const nums = document.querySelectorAll<HTMLElement>('.stat-num');
  let triggered = false;

  const observer = new IntersectionObserver(entries => {
    if (triggered) return;
    if (entries.some(e => e.isIntersecting)) {
      triggered = true;
      nums.forEach(el => {
        const raw = el.dataset.target ?? '';
        const digits = parseFloat(raw.replace(/[^0-9.]/g, ''));
        if (isNaN(digits)) return;
        const prefix = raw.match(/^[^0-9]*/)?.[0] ?? '';
        const suffix = raw.match(/[^0-9.]*$/)?.[0] ?? '';
        const start  = performance.now();
        const dur    = 900;
        function tick(now: number) {
          const t  = Math.min((now - start) / dur, 1);
          const e2 = 1 - Math.pow(1 - t, 3);
          const v  = digits * e2;
          el.textContent = prefix + (Number.isInteger(digits) ? Math.round(v).toString() : v.toFixed(1)) + suffix;
          if (t < 1) requestAnimationFrame(tick);
        }
        if (window.matchMedia('(prefers-reduced-motion: no-preference)').matches) {
          requestAnimationFrame(tick);
        }
      });
    }
  }, { threshold: 0.3 });

  nums.forEach(el => observer.observe(el));
</script>
