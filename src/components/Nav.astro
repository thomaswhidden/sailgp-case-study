---
import { url } from '../utils/url';
const pathname = Astro.url.pathname;

const groups = [
  {
    label: 'Brief',
    href:  url('/'),
    exact: true,
    children: [] as { href: string; label: string }[],
  },
  {
    label: 'The League',
    href:  null,
    exact: false,
    children: [
      { href: url('/timeline'), label: 'Story' },
      { href: url('/teams'),    label: 'Teams' },
    ],
  },
  {
    label: 'Research',
    href:  null,
    exact: false,
    children: [
      { href: url('/framework'),      label: 'Framework' },
      { href: url('/comparables'),    label: 'Comparables' },
      { href: url('/interviews'),     label: 'Interviews' },
      { href: url('/interview-prep'), label: 'Questions' },
      { href: url('/sources'),        label: 'Sources' },
      { href: url('/case-draft'),     label: 'Draft' },
    ],
  },
];

function isActive(href: string, exact = false): boolean {
  if (exact) return pathname === href;
  return pathname === href || pathname.startsWith(href + '/');
}

function groupActive(g: typeof groups[0]): boolean {
  if (g.href) return isActive(g.href, g.exact);
  return g.children.some(c => isActive(c.href));
}
---

<nav
  class="sticky top-0 z-50 flex items-center justify-between px-6 md:px-10 lg:px-16"
  style="background: rgba(242,235,221,0.95); backdrop-filter: blur(8px); border-bottom: 1px solid rgba(11,31,38,0.12); height: 56px; overflow: visible;"
>
  <!-- Wordmark -->
  <a href={url('/')} class="flex items-center gap-3 shrink-0 no-underline" style="text-decoration: none;">
    <div style="width:20px;height:20px;position:relative;flex-shrink:0;">
      <div style="position:absolute;inset:0;background:#0B1F26;clip-path:polygon(0 100%, 100% 100%, 50% 0);"></div>
    </div>
    <span style="font-family:'Instrument Serif',Georgia,serif;font-size:19px;letter-spacing:-0.01em;line-height:1;color:#0B1F26;">
      Foiling / a case study
    </span>
  </a>

  <!-- Nav groups -->
  <div class="flex items-stretch gap-6" style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.15em;text-transform:uppercase;height:56px;">
    {groups.map(group => {
      const active = groupActive(group);
      return group.href ? (
        <a
          href={group.href}
          class="nav-direct shrink-0 whitespace-nowrap no-underline flex items-center"
          style={`color:${active ? '#E97451' : '#5A6E76'};border-bottom:${active ? '1px solid #E97451' : 'none'};`}
        >
          {group.label}
        </a>
      ) : (
        <div class="nav-group">
          <button
            class="nav-trigger"
            style={`color:${active ? '#E97451' : '#5A6E76'};border-bottom:${active ? '1px solid #E97451' : 'none'};`}
          >
            {group.label}
            <svg width="8" height="5" viewBox="0 0 8 5" fill="none" style="flex-shrink:0;margin-top:1px;">
              <path d="M1 1l3 3 3-3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <div class="nav-dropdown">
            {group.children.map(child => {
              const childActive = isActive(child.href);
              return (
                <a
                  href={child.href}
                  class="nav-dropdown-item"
                  style={`color:${childActive ? '#E97451' : '#5A6E76'};`}
                >
                  {child.label}
                </a>
              );
            })}
          </div>
        </div>
      );
    })}
  </div>

  <!-- Search -->
  <div class="shrink-0 w-36 ml-5 hidden md:block">
    <div id="search"></div>
  </div>
</nav>

<style>
  /* Group fills the full nav height — this is the hover target */
  .nav-group {
    position: relative;
    display: flex;
    align-items: center;
    height: 56px;
  }

  .nav-trigger {
    display: flex;
    align-items: center;
    gap: 4px;
    height: 100%;
    padding: 0;
    background: none;
    border: none;
    border-bottom: none;
    cursor: pointer;
    font-family: inherit;
    font-size: inherit;
    letter-spacing: inherit;
    text-transform: inherit;
    white-space: nowrap;
  }

  /* Dropdown — no gap from the trigger so hover stays live */
  .nav-dropdown {
    display: none;
    position: absolute;
    top: 100%; /* flush with bottom of the 56px nav-group */
    left: 50%;
    transform: translateX(-50%);
    background: rgba(242,235,221,0.98);
    border: 1px solid rgba(11,31,38,0.12);
    border-top: none;
    backdrop-filter: blur(8px);
    padding: 6px 0;
    min-width: 140px;
    z-index: 9999;
  }

  /* Show on hover — gap-free so the mouse can travel straight down */
  .nav-group:hover .nav-dropdown {
    display: block;
  }

  .nav-dropdown-item {
    display: block;
    padding: 9px 18px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    transition: color 150ms;
  }

  .nav-dropdown-item:hover { color: #E97451 !important; }
</style>

<script>
  if (typeof window !== 'undefined' && (window as any).PagefindUI) {
    new (window as any).PagefindUI({
      element: '#search',
      showSubResults: false,
      resetStyles: false,
    });
  }
</script>
