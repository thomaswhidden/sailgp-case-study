---
interface SourceRef {
  label: string;
  url: string;
}
interface Props {
  date: string;
  category: string;
  title: string;
  summary: string;
  sources?: SourceRef[];
}
const { date, category, title, summary, sources = [] } = Astro.props;

const catColors: Record<string, string> = {
  founding:    'var(--ink-2)',
  season:      'var(--ink)',
  'team-sale': 'var(--sun)',
  broadcast:   'var(--ink-2)',
  sponsor:     'var(--ink-2)',
  incident:    'var(--sun)',
  governance:  'var(--mute)',
  venue:       'var(--mute)',
  operations:  'var(--mute)',
  athlete:     'var(--ink-2)',
  other:       'var(--mute)',
};
const c = catColors[category] ?? 'var(--ink)';
---

<div
  class="timeline-item"
  data-cat={category}
  style="display:grid;grid-template-columns:90px 28px 1fr;gap:12px;padding:14px 0;align-items:start;"
>
  <div class="type-eyebrow" style="color:var(--mute);text-align:right;padding-top:5px;">{date}</div>

  <div style="display:flex;justify-content:center;padding-top:5px;">
    <div class="tl-dot" style={`width:13px;height:13px;border-radius:50%;background:var(--bone);border:2px solid ${c};`}></div>
  </div>

  <div>
    <div style="display:flex;align-items:baseline;gap:10px;flex-wrap:wrap;margin-bottom:4px;">
      <span class="type-eyebrow" style={`color:${c};font-weight:600;`}>{category}</span>
      <span style="font-family:var(--font-display);font-size:22px;letter-spacing:-0.015em;color:var(--ink);">{title}</span>
    </div>
    <p style="font-family:var(--font-serif);font-size:14px;color:rgba(11,31,38,0.65);line-height:1.55;max-width:680px;margin:0 0 6px;">{summary}</p>
    {sources.length > 0 && (
      <div style="display:flex;flex-wrap:wrap;gap:5px;margin-top:5px;">
        {sources.map(src => (
          <a
            href={src.url}
            target="_blank"
            rel="noopener"
            class="type-eyebrow"
            style="font-size:8px;letter-spacing:0.12em;padding:2px 7px;border:1px solid rgba(11,31,38,0.15);color:rgba(11,31,38,0.4);text-decoration:none;transition:color 0.15s,border-color 0.15s;"
            onmouseover="this.style.color='var(--sun)';this.style.borderColor='var(--sun)';"
            onmouseout="this.style.color='rgba(11,31,38,0.4)';this.style.borderColor='rgba(11,31,38,0.15)';"
          >
            ↗ {src.label}
          </a>
        ))}
      </div>
    )}
  </div>
</div>
