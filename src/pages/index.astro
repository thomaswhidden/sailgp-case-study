---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import StatBand from '../components/StatBand.astro';
import { sailgpImages } from '../data/teamImages';
import { url } from '../utils/url';

const homeStats = [
  { value: '$200M+', label: 'Season 5 revenue',            source: 'Fast Company · Nov 2025', sourceUrl: 'https://www.fastcompany.com/91449460/how-sailgp-turned-the-niche-sport-into-a-200-million-a-celebrity-investment-magnet' },
  { value: '3.47M',  label: 'Abu Dhabi US viewers',        source: 'SailGP.com',              sourceUrl: 'https://sailgp.com' },
  { value: '$26.2M', label: 'Avg regional economic impact',source: 'SailGP Media Hub',        sourceUrl: 'https://mediahub.sailgp.com' },
  { value: '+58',    label: 'Average event NPS',           source: 'Business of Sport · Aug 2025', sourceUrl: 'https://www.youtube.com/watch?v=OVYq2YDIGsg' },
  { value: '112k+',  label: 'Ticketed spectators, 2025',   source: 'Fast Company · Nov 2025', sourceUrl: 'https://www.fastcompany.com/91449460/how-sailgp-turned-the-niche-sport-into-a-200-million-a-celebrity-investment-magnet' },
];

const sections = [
  { href: url('/timeline'),      label: 'Story',       desc: 'From Ellison\'s idea to thirteen flags — every milestone.' },
  { href: url('/teams'),         label: 'Teams',       desc: 'Thirteen franchises, thirteen ownership stories.' },
  { href: url('/framework'),     label: 'Framework',   desc: 'Foster\'s 13-criterion sports business analysis.' },
  { href: url('/comparables'),   label: 'Comparables', desc: 'F1, IPL, UFC, LIV Golf — how SailGP measures up.' },
  { href: url('/interviews'),    label: 'Interviews',  desc: 'Coutts\'s public record + the drafting question bank.' },
  { href: url('/interview-prep'),label: 'Questions',   desc: '25 final interview questions organized by category.' },
  { href: url('/sources'),       label: 'Sources',     desc: 'Full bibliography of research used in this case.' },
];
---

<Base>
  <div style="background:var(--bone);color:var(--ink);min-height:100vh;">
    <Nav />

    <!-- ══ HERO ══════════════════════════════════════════════════ -->
    <section
      class="px-6 md:px-10 lg:px-16"
      style="padding-top:clamp(56px,9vw,96px);padding-bottom:clamp(32px,5vw,48px);"
    >
      <div class="grid grid-cols-1 lg:[grid-template-columns:7fr_5fr]" style="gap:clamp(28px,5vw,56px);align-items:center;">
        <div>
          <div class="eyebrow-marker mb-6">Stanford GSB · Working Case · 2026</div>
          <h1 class="type-hero" style="margin:0 0 28px;">
            Eight seasons<br/>above <em style="color:var(--sun);">the water.</em>
          </h1>
          <p class="type-body-lead" style="color:rgba(11,31,38,0.75);max-width:560px;margin:0 0 28px;">
            A Stanford GSB case study with Professor George Foster on how SailGP turned a six-team Ellison experiment into a thirteen-nation league worth $200 million — and what it must do to scale to twenty.
          </p>
          <div style="display:flex;flex-wrap:wrap;gap:24px;align-items:center;font-family:var(--font-mono);font-size:10px;letter-spacing:0.15em;text-transform:uppercase;color:var(--mute);">
            <span>Advised by Stanford GSB Professor George Foster</span>
            <span style="width:16px;height:1px;background:rgba(11,31,38,0.25);display:inline-block;"></span>
            <span>Written by <a href="mailto:twhidden@stanford.edu" style="color:inherit;text-decoration:underline;text-underline-offset:3px;">Thomas Whidden</a></span>
          </div>
        </div>

        <div style="position:relative;" class="hidden lg:block">
          <div style="height:420px;overflow:hidden;position:relative;">
            <img
              src={sailgpImages.hero.url}
              alt={sailgpImages.hero.alt}
              loading="eager"
              style="width:100%;height:115%;object-fit:cover;object-position:center 40%;position:absolute;top:-7.5%;"
            />
            <div style="position:absolute;inset:0;background:linear-gradient(to bottom, transparent 60%, rgba(11,31,38,0.3) 100%);"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ══ STAT BAND ══════════════════════════════════════════════ -->
    <StatBand stats={homeStats} />

    <!-- ══ SECTION DIRECTORY ══════════════════════════════════════ -->
    <section class="px-6 md:px-10 lg:px-16" style="padding-top:16px;padding-bottom:72px;">
      <div class="eyebrow-marker mb-8">Navigate the case</div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4" style="gap:2px;">
        {sections.map(s => (
          <a
            href={s.href}
            class="card-hover"
            style="padding:24px 20px;background:var(--bone-2);text-decoration:none;display:block;"
          >
            <div class="type-eyebrow mb-2" style="color:var(--sun);">{s.label}</div>
            <p style="font-family:var(--font-serif);font-size:14px;color:rgba(11,31,38,0.65);line-height:1.5;margin:0;">{s.desc}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- ══ FOOTER ══════════════════════════════════════════════════ -->
    <footer style="background:var(--ink);">
      <div class="px-6 md:px-10 lg:px-16 py-10 flex flex-col sm:flex-row justify-between gap-6">
        <span class="type-eyebrow" style="color:rgba(242,235,221,0.5);">Foiling · A Stanford GSB case study</span>
        <span class="type-eyebrow" style="color:rgba(242,235,221,0.35);">With Prof. George Foster · v0.08</span>
        <span class="type-eyebrow" style="color:rgba(242,235,221,0.25);">Local research instrument · Not for distribution</span>
      </div>
    </footer>
  </div>
</Base>
