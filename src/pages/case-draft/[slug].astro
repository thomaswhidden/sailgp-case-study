---
import Section from '../../layouts/Section.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const sections = await getCollection('case-draft');
  return sections.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { section_number, title, part, status, last_updated } = entry.data;

// Build prev/next navigation
const order = ['0','A-I','A-II','A-III','A-IV','B-I','B-II','B-III','exhibits','matrix'];
const all = [...(await getCollection('case-draft'))].sort(
  (a, b) => order.indexOf(a.data.section_number) - order.indexOf(b.data.section_number)
);
const idx = all.findIndex(s => s.slug === entry.slug);
const prev = idx > 0 ? all[idx - 1] : null;
const next = idx < all.length - 1 ? all[idx + 1] : null;

const partLabel = part === 'cover' ? 'Preface'
  : part === 'A' ? `Part A · Section ${section_number.replace('A-','')}`
  : part === 'B' ? `Part B · Section ${section_number.replace('B-','')}`
  : section_number === 'exhibits' ? 'Exhibits'
  : 'Interview Matrix';

const chapterLabel = `Case Draft · Stanford GSB · ${partLabel}`;
---

<Section title={title} chapter={chapterLabel}>

  <!-- Status + print bar -->
  <div class="no-print" style="display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:12px;margin-bottom:28px;padding-bottom:20px;border-bottom:1px solid var(--border-ink);">
    <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
      <span style="font-family:var(--font-mono);font-size:9px;letter-spacing:0.15em;text-transform:uppercase;padding:3px 8px;background:rgba(220,38,38,0.12);color:#DC2626;border:1px solid rgba(220,38,38,0.25);">
        {status.toUpperCase()}
      </span>
      {last_updated && (
        <span class="type-eyebrow" style="color:var(--mute);">Updated {last_updated}</span>
      )}
      <a href="/open-questions" class="type-eyebrow link-sun">Open Questions →</a>
    </div>
    <div style="display:flex;gap:12px;">
      <button onclick="window.print()" class="type-eyebrow" style="padding:5px 12px;border:1px solid var(--border-ink);background:transparent;color:var(--mute);cursor:pointer;">
        Print section
      </button>
      <a href="/case-draft/print" class="type-eyebrow" style="padding:5px 12px;border:1px solid var(--border-ink);color:var(--mute);text-decoration:none;">
        Print all
      </a>
    </div>
  </div>

  <!-- Main content -->
  <div class="prose max-w-none case-draft-content">
    <Content />
  </div>

  <!-- Prev / Next navigation -->
  <div class="no-print" style="display:flex;justify-content:space-between;gap:16px;margin-top:40px;padding-top:28px;border-top:1px solid var(--border-ink);">
    {prev ? (
      <a href={`/case-draft/${prev.slug}`} style="text-decoration:none;max-width:45%;">
        <div class="type-eyebrow mb-1" style="color:var(--mute);">← Previous</div>
        <div style="font-family:var(--font-serif);font-size:14px;color:var(--ink);">{prev.data.title}</div>
      </a>
    ) : <div />}
    {next ? (
      <a href={`/case-draft/${next.slug}`} style="text-decoration:none;text-align:right;max-width:45%;">
        <div class="type-eyebrow mb-1" style="color:var(--mute);">Next →</div>
        <div style="font-family:var(--font-serif);font-size:14px;color:var(--ink);">{next.data.title}</div>
      </a>
    ) : <div />}
  </div>

  <div class="no-print" style="margin-top:16px;">
    <a href="/case-draft" class="link-sun type-eyebrow">← All sections</a>
  </div>

</Section>

<style>
  /* Tighten list spacing for dense outline content */
  .case-draft-content ul { margin: 0.5em 0 0.75em; }
  .case-draft-content li { margin-bottom: 0.6em; line-height: 1.6; }
  .case-draft-content li > em { color: rgba(11,31,38,0.65); font-style: italic; }

  /* Section divider hr */
  .case-draft-content hr {
    border: none;
    border-top: 1px solid var(--border-ink);
    margin: 2rem 0;
  }

  /* Print: one section per page with clean header */
  @media print {
    .case-draft-content { font-size: 11pt; line-height: 1.6; }
    .case-draft-content h2 {
      font-size: 13pt;
      margin-top: 2em;
      break-after: avoid;
    }
    .case-draft-content ul { margin: 0.4em 0; }
    .case-draft-content li { font-size: 10.5pt; margin-bottom: 0.4em; break-inside: avoid; }
    .quote-placeholder { border-left: 2px solid #DC2626; padding: 10px 14px; background: #fff8f8; break-inside: avoid; }
    .exhibit-callout { break-inside: avoid; margin: 12pt 0; padding: 10pt 12pt; background: #f5f5f5; }
  }
</style>
