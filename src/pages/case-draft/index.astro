---
import Section from '../../layouts/Section.astro';
import { getCollection } from 'astro:content';

const order = ['0','A-I','A-II','A-III','A-IV','B-I','B-II','B-III','exhibits','matrix'];
const sections = [...(await getCollection('case-draft'))].sort(
  (a, b) => order.indexOf(a.data.section_number) - order.indexOf(b.data.section_number)
);

const partA = sections.filter(s => s.data.part === 'A' || s.data.part === 'cover');
const partB = sections.filter(s => s.data.part === 'B');
const appendix = sections.filter(s => s.data.part === 'exhibits' || s.data.part === 'matrix');

const interviewCount = 42;
---

<Section
  title="From Harbor to Horizon."
  chapter="Case Draft · Stanford GSB · Professor George Foster"
  description="Working draft of the SailGP case study. All sections are in outline form. Sections marked with INTERVIEW NEEDED require the Coutts interview."
  dark={true}
>
  <!-- Draft status banner -->
  <div style="margin-bottom:32px;padding:16px 20px;background:rgba(220,38,38,0.12);border:1px solid rgba(220,38,38,0.3);display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:12px;">
    <div style="display:flex;align-items:center;gap:12px;">
      <span style="font-family:var(--font-mono);font-size:10px;letter-spacing:0.15em;text-transform:uppercase;color:#DC2626;font-weight:700;">DRAFT ONLY</span>
      <span class="type-eyebrow" style="color:rgba(242,235,221,0.6);">NOT TO BE DISTRIBUTED BEYOND GSB</span>
    </div>
    <div style="display:flex;align-items:center;gap:16px;">
      <span class="type-eyebrow" style="color:rgba(242,235,221,0.5);">{interviewCount} INTERVIEW NEEDED markers</span>
      <a href="/case-draft/print" class="type-eyebrow no-print" style="color:var(--sun);text-decoration:none;">Print all →</a>
    </div>
  </div>

  <!-- Part A -->
  <div style="margin-bottom:40px;">
    <div class="eyebrow-marker mb-6" style="color:var(--bone);">Part A — "From Harbor to Horizon"</div>
    <div style="display:flex;flex-direction:column;gap:2px;">
      {partA.map(section => {
        const isCover = section.data.part === 'cover';
        return (
          <a
            href={`/case-draft/${section.slug}`}
            style={`
              display:grid;
              grid-template-columns:80px 1fr auto;
              gap:16px;
              align-items:center;
              padding:18px 20px;
              background:${isCover ? 'rgba(242,235,221,0.06)' : 'rgba(242,235,221,0.04)'};
              border:1px solid rgba(242,235,221,0.1);
              text-decoration:none;
              transition:background 150ms;
            `}
            class="card-hover-dark"
          >
            <span style="font-family:var(--font-mono);font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:rgba(242,235,221,0.35);">
              {isCover ? 'Preface' : `§ ${section.data.section_number}`}
            </span>
            <span style="font-family:var(--font-display);font-size:18px;color:var(--bone);line-height:1.2;letter-spacing:-0.01em;">
              {section.data.title}
            </span>
            <span style="font-family:var(--font-mono);font-size:9px;letter-spacing:0.1em;text-transform:uppercase;color:rgba(220,38,38,0.7);white-space:nowrap;">
              {section.data.status}
            </span>
          </a>
        );
      })}
    </div>
  </div>

  <!-- Part B -->
  <div style="margin-bottom:40px;">
    <div class="eyebrow-marker mb-6" style="color:var(--bone);">Part B — "Choosing the Next Phase"</div>
    <div style="display:flex;flex-direction:column;gap:2px;">
      {partB.map(section => (
        <a
          href={`/case-draft/${section.slug}`}
          style="display:grid;grid-template-columns:80px 1fr auto;gap:16px;align-items:center;padding:18px 20px;background:rgba(242,235,221,0.04);border:1px solid rgba(242,235,221,0.1);text-decoration:none;transition:background 150ms;"
          class="card-hover-dark"
        >
          <span style="font-family:var(--font-mono);font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:rgba(242,235,221,0.35);">
            § {section.data.section_number}
          </span>
          <span style="font-family:var(--font-display);font-size:18px;color:var(--bone);line-height:1.2;letter-spacing:-0.01em;">
            {section.data.title}
          </span>
          <span style="font-family:var(--font-mono);font-size:9px;letter-spacing:0.1em;text-transform:uppercase;color:rgba(220,38,38,0.7);white-space:nowrap;">
            {section.data.status}
          </span>
        </a>
      ))}
    </div>
  </div>

  <!-- Appendices -->
  <div>
    <div class="eyebrow-marker mb-6" style="color:var(--bone);">Appendices</div>
    <div style="display:flex;flex-direction:column;gap:2px;">
      {appendix.map(section => (
        <a
          href={`/case-draft/${section.slug}`}
          style="display:grid;grid-template-columns:80px 1fr auto;gap:16px;align-items:center;padding:18px 20px;background:rgba(242,235,221,0.04);border:1px solid rgba(242,235,221,0.1);text-decoration:none;transition:background 150ms;"
          class="card-hover-dark"
        >
          <span style="font-family:var(--font-mono);font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:rgba(242,235,221,0.35);">
            {section.data.section_number}
          </span>
          <span style="font-family:var(--font-display);font-size:18px;color:var(--bone);line-height:1.2;letter-spacing:-0.01em;">
            {section.data.title}
          </span>
          <span style="font-family:var(--font-mono);font-size:9px;letter-spacing:0.1em;text-transform:uppercase;color:rgba(220,38,38,0.7);white-space:nowrap;">
            {section.data.status}
          </span>
        </a>
      ))}
    </div>
  </div>

  <div class="mt-12 pt-10" style="border-top:1px solid rgba(242,235,221,0.12);">
    <p class="type-body-small" style="color:rgba(242,235,221,0.4);">
      Modeled on the Foster PSG case structure. All content is draft and unverified where marked
      <span class="interview-needed" style="font-size:8px;">INTERVIEW NEEDED</span>.
      Last updated 2026-04-27.
    </p>
  </div>
</Section>

<style>
  .card-hover-dark:hover { background: rgba(242,235,221,0.08) !important; }
</style>
