---
import Section from '../../layouts/Section.astro';
import { getCollection } from 'astro:content';
import { url } from '../../utils/url';

const questions = await getCollection('interview-prep');
const active = questions.filter(q => q.data.status !== 'cut').sort((a, b) => a.data.order - b.data.order);
const cut    = questions.filter(q => q.data.status === 'cut');
const confirmed = questions.filter(q => q.data.status === 'confirmed');
const draft     = questions.filter(q => q.data.status === 'draft');

const frameworkLabels: Record<string, string> = {
  'vision-strategic-positioning': '01 Vision',
  'investor-owner-base':          '02 Investors',
  'league-governance':            '03 Governance',
  'competitive-format':           '04 Format',
  'athlete-talent-pool':          '05 Talent',
  'venue-host-city':              '06 Venues',
  'broadcast-media':              '07 Broadcast',
  'sponsorship':                  '08 Sponsorship',
  'fan-engagement':               '09 Fans',
  'financial-sustainability':     '10 Financials',
  'growth-opportunities':         '11 Growth+',
  'growth-challenges':            '12 Growth−',
  'disruptive-positioning':       '13 Disruption',
};

const statusPill: Record<string, string> = {
  confirmed: 'background:var(--sun);color:var(--bone);',
  draft:     'background:rgba(11,31,38,0.08);color:var(--mute);',
  cut:       'background:transparent;color:var(--mute);border:1px solid var(--border-ink);text-decoration:line-through;',
};

const CATEGORY_ORDER = [
  'Origins & Founding',
  'Financials & Unit Economics',
  'Expansion & Growth',
  'Governance & Ownership',
  'Competitive Format & Technology',
  'Media & Broadcast',
  'Strategic Future',
];

const grouped = new Map<string, typeof active>();
for (const cat of CATEGORY_ORDER) grouped.set(cat, []);
for (const q of active) {
  const cat = q.data.category ?? 'Uncategorized';
  if (!grouped.has(cat)) grouped.set(cat, []);
  grouped.get(cat)!.push(q);
}

let globalIndex = 0;
const indexedGroups = [...grouped.entries()]
  .filter(([, qs]) => qs.length > 0)
  .map(([cat, qs]) => ({
    cat,
    items: qs.map(q => ({ q, n: ++globalIndex })),
  }));
---

<Section
  title="Interview Prep"
  chapter="Final Question Set · Coutts"
  description={`${active.length} questions across ${indexedGroups.length} categories. ${confirmed.length} confirmed · ${draft.length} draft.`}
>
  <!-- Export -->
  <div style="display:flex;justify-content:flex-end;margin-bottom:40px;">
    <button
      id="export-btn"
      class="type-eyebrow"
      style="padding:6px 16px;border:1px solid var(--border-ink);background:transparent;color:var(--mute);cursor:pointer;"
    >
      Export → Text
    </button>
  </div>

  {active.length === 0 ? (
    <div style="padding:48px 0;text-align:center;">
      <p class="type-body" style="color:var(--mute);">
        No questions yet. Create files in <code style="font-family:var(--font-mono);font-size:13px;background:var(--bone-2);padding:1px 4px;">src/content/interview-prep/</code>.
      </p>
    </div>
  ) : (
    <div id="question-list">
      {indexedGroups.map(({ cat, items }) => (
        <div style="margin-bottom:48px;">
          <!-- Category header -->
          <div style="display:flex;align-items:center;gap:16px;margin-bottom:8px;">
            <span class="type-eyebrow" style="color:var(--sun);letter-spacing:0.18em;">{cat.toUpperCase()}</span>
            <div style="flex:1;height:1px;background:rgba(11,31,38,0.15);"></div>
            <span class="type-eyebrow" style="color:var(--mute);">{items.length} Q</span>
          </div>

          <ol style="list-style:none;padding:0;margin:0;">
            {items.map(({ q, n }) => (
              <li
                data-status={q.data.status}
                style={`display:grid;grid-template-columns:60px 1fr;gap:18px;align-items:start;padding:22px 0;border-bottom:1px solid var(--border-ink);${q.data.status === 'cut' ? 'opacity:0.4;' : ''}`}
              >
                <!-- Global index -->
                <div style="font-family:var(--font-display);font-size:36px;color:rgba(11,31,38,0.18);line-height:1;letter-spacing:-0.02em;">
                  {String(n).padStart(2, '0')}
                </div>

                <!-- Question + meta -->
                <div>
                  <p
                    style={`font-family:var(--font-serif);font-size:18px;line-height:1.4;color:var(--ink);margin:0 0 10px;${q.data.status === 'cut' ? 'text-decoration:line-through;color:var(--mute);' : ''}`}
                  >
                    {q.data.question}
                  </p>
                  {q.data.framework_links.length > 0 && (
                    <div style="display:flex;flex-wrap:wrap;gap:6px;">
                      {q.data.framework_links.map((slug: string) => (
                        <a
                          href={url(`/framework/${slug}`)}
                          class="type-eyebrow"
                          style="padding:3px 8px;background:var(--bone-2);border:1px solid var(--border-ink);color:var(--ink-2);text-decoration:none;"
                        >
                          {frameworkLabels[slug] ?? slug}
                        </a>
                      ))}
                    </div>
                  )}
                </div>

              </li>
            ))}
          </ol>
        </div>
      ))}
    </div>
  )}

  <div class="mt-12 pt-10" style="border-top:1px solid var(--border-ink);">
    <p class="type-body-small" style="color:var(--mute);">
      Create <code style="font-family:var(--font-mono);font-size:12px;background:var(--bone-2);padding:1px 4px;">src/content/interview-prep/NN-slug.md</code>
      with <code style="font-family:var(--font-mono);font-size:12px;background:var(--bone-2);padding:1px 4px;">order, question, category, status</code>.
    </p>
  </div>
</Section>

<script>
  const btn = document.getElementById('export-btn') as HTMLButtonElement;
  btn?.addEventListener('click', () => {
    const sections = document.querySelectorAll<HTMLElement>('#question-list > div');
    const lines: string[] = ['INTERVIEW PREP — SailGP / Russell Coutts\n'];
    sections.forEach(sec => {
      const catEl = sec.querySelector('.type-eyebrow');
      if (catEl) lines.push('\n' + catEl.textContent?.trim() + '\n' + '─'.repeat(40));
      const items = sec.querySelectorAll<HTMLElement>('li');
      items.forEach(li => {
        if (li.dataset.status === 'cut') return;
        const num = li.querySelector('[style*="36px"]')?.textContent?.trim() ?? '';
        const q   = li.querySelector('p')?.textContent?.trim() ?? '';
        lines.push(`${num}. ${q}`);
      });
    });
    const blob = new Blob([lines.join('\n')], { type: 'text/plain' });
    const a    = document.createElement('a');
    a.href     = URL.createObjectURL(blob);
    a.download = 'sailgp-interview-questions.txt';
    a.click();
  });
</script>
