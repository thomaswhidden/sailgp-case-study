---
import Section from '../../layouts/Section.astro';
import { getCollection } from 'astro:content';
import { url } from '../../utils/url';

const interviews     = await getCollection('interviews');
const openQuestions  = await getCollection('open-questions');
const allInterviews  = await getCollection('interviews');

const sorted = [...interviews].sort((a, b) => b.data.date.localeCompare(a.data.date));

const allTags = [...new Set(interviews.flatMap(i => i.data.already_asked_tags))].sort();

const interviewBySlug = Object.fromEntries(allInterviews.map(iv => [iv.slug, iv]));
const priorityOrder: Record<string, number> = { high: 0, medium: 1, low: 2 };
const sortedQuestions = [...openQuestions].sort((a, b) =>
  (priorityOrder[a.data.priority] ?? 9) - (priorityOrder[b.data.priority] ?? 9)
);

const rendered = await Promise.all(
  sortedQuestions.map(async (theme) => {
    const { Content } = await theme.render();
    return { theme, Content };
  })
);

const frameworkLabels: Record<string, string> = {
  'vision-strategic-positioning': '01 Vision',
  'investor-owner-base':          '02 Investors',
  'league-governance':            '03 Governance',
  'competitive-format':           '04 Format',
  'athlete-talent-pool':          '05 Talent',
  'venue-host-city':              '06 Venues',
  'broadcast-media':              '07 Broadcast',
  'sponsorship':                  '08 Sponsorship',
  'fan-engagement':               '09 Fans',
  'financial-sustainability':     '10 Financials',
  'growth-opportunities':         '11 Growth+',
  'growth-challenges':            '12 Growth−',
  'disruptive-positioning':       '13 Disruption',
};

const highCount  = sortedQuestions.filter(t => t.data.priority === 'high').length;
const medCount   = sortedQuestions.filter(t => t.data.priority === 'medium').length;
const askedCount = sortedQuestions.filter(t => t.data.already_asked).length;
---

<Section
  title="Interview Archive"
  chapter="Russell Coutts · Public Record"
  description="Q&A summaries of every public Coutts interview, followed by the drafting question bank."
>

  <!-- ── INTERVIEW ARCHIVE ─────────────────────────────────────── -->

  {allTags.length > 0 && (
    <div style="margin-bottom:36px;padding:20px 24px;background:var(--bone-2);">
      <div class="eyebrow-marker mb-4">Topics already covered across all interviews</div>
      <div style="display:flex;flex-wrap:wrap;gap:6px;">
        {allTags.map((tag: string) => (
          <span
            class="type-eyebrow"
            style="padding:4px 10px;background:var(--bone);border:1px solid var(--border-ink);color:var(--mute);"
          >
            {tag}
          </span>
        ))}
      </div>
    </div>
  )}

  <div style="display:flex;flex-direction:column;gap:2px;margin-bottom:72px;">
    {sorted.map(interview => (
      <a
        href={url(`/interviews/${interview.slug}`)}
        class="card-hover block"
        style="padding:24px;text-decoration:none;"
      >
        <div class="eyebrow-marker mb-3" style="color:var(--sun);">{interview.data.outlet}</div>
        <h2 style="font-family:var(--font-display);font-size:clamp(22px,3vw,30px);line-height:1.05;letter-spacing:-0.015em;color:var(--ink);margin:0 0 10px;">
          {interview.data.title}
        </h2>
        <div style="display:flex;flex-wrap:wrap;gap:14px;align-items:center;margin-bottom:12px;">
          <span class="type-eyebrow" style="color:var(--mute);">{interview.data.date}</span>
          {interview.data.interviewer && (
            <span class="type-eyebrow" style="color:var(--mute);">{interview.data.interviewer}</span>
          )}
          <span class="type-eyebrow" style="color:var(--mute);">{interview.data.format}</span>
          <span class="type-eyebrow" style="color:var(--sun);">
            {interview.data.already_asked_tags.length} topics covered →
          </span>
        </div>
        {interview.data.key_topics.length > 0 && (
          <div style="display:flex;flex-wrap:wrap;gap:6px;">
            {interview.data.key_topics.map((t: string) => (
              <span class="type-eyebrow" style="padding:3px 8px;background:var(--bone-2);color:var(--mute);border:1px solid var(--border-ink);">
                {t}
              </span>
            ))}
          </div>
        )}
      </a>
    ))}
  </div>

  <!-- ── DRAFTING QUESTIONS ────────────────────────────────────── -->

  <div style="border-top:2px solid var(--border-ink);padding-top:56px;margin-bottom:32px;">
    <div class="eyebrow-marker mb-4" style="color:var(--sun);">Drafting Questions</div>
    <h2 style="font-family:var(--font-display);font-size:clamp(28px,4vw,42px);line-height:1.05;letter-spacing:-0.02em;color:var(--ink);margin:0 0 12px;">
      What the public record won't say.
    </h2>
    <p class="type-body" style="color:rgba(11,31,38,0.65);max-width:600px;margin:0 0 32px;">
      {sortedQuestions.length} question themes, priority-sorted. {askedCount} already covered in public interviews.
    </p>

    <!-- Filter pills -->
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:32px;">
      <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <button class="dq-pill type-eyebrow" data-filter="all" style="padding:6px 14px;background:var(--ink);color:var(--bone);border:none;cursor:pointer;">
          All · {sortedQuestions.length}
        </button>
        <button class="dq-pill type-eyebrow" data-filter="high" style="padding:6px 14px;background:var(--sun);color:var(--bone);border:none;cursor:pointer;">
          High · {highCount}
        </button>
        <button class="dq-pill type-eyebrow" data-filter="medium" style="padding:6px 14px;background:transparent;color:var(--mute);border:1px solid var(--border-ink);cursor:pointer;">
          Med · {medCount}
        </button>
      </div>
      <button
        id="dq-toggle-asked"
        class="type-eyebrow"
        style="padding:6px 14px;border:1px solid var(--border-ink);background:transparent;color:var(--mute);cursor:pointer;"
      >
        Hide already-asked
      </button>
    </div>
  </div>

  <div id="dq-list">
    {rendered.map(({ theme, Content }, i) => {
      const pillBg  = theme.data.priority === 'high' ? 'var(--sun)' : 'rgba(11,31,38,0.08)';
      const pillCol = theme.data.priority === 'high' ? 'var(--bone)' : 'var(--mute)';
      return (
        <div
          id={theme.slug}
          class="dq-block"
          data-asked={String(theme.data.already_asked)}
          data-priority={theme.data.priority}
          style="display:grid;grid-template-columns:60px 1fr 110px;gap:18px;align-items:start;padding:22px 0;border-bottom:1px solid var(--border-ink);"
        >
          <div style="font-family:var(--font-display);font-size:36px;color:rgba(11,31,38,0.18);line-height:1;letter-spacing:-0.02em;">
            {String(i + 1).padStart(2, '0')}
          </div>

          <div>
            <div style="display:flex;align-items:baseline;gap:10px;flex-wrap:wrap;margin-bottom:10px;">
              <h3 style="font-family:var(--font-display);font-size:22px;line-height:1.05;letter-spacing:-0.015em;color:var(--ink);margin:0;">{theme.data.theme}</h3>
              {theme.data.already_asked && (
                <span class="type-eyebrow" style="color:var(--mute);">already asked</span>
              )}
            </div>

            {(theme.data.framework_links.length > 0 || theme.data.source_check.length > 0) && (
              <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px;">
                {theme.data.framework_links.map((slug: string) => (
                  <a
                    href={url(`/framework/${slug}`)}
                    class="type-eyebrow"
                    style="padding:3px 8px;background:var(--bone-2);border:1px solid var(--border-ink);color:var(--ink-2);text-decoration:none;"
                  >
                    {frameworkLabels[slug] ?? slug}
                  </a>
                ))}
                {theme.data.source_check.filter((s: string) => interviewBySlug[s]).map((s: string) => (
                  <a
                    href={url(`/interviews/${s}`)}
                    class="type-eyebrow"
                    style="padding:3px 8px;background:rgba(233,116,81,0.12);border:1px solid rgba(233,116,81,0.3);color:var(--sun);text-decoration:none;"
                  >
                    ↗ {interviewBySlug[s].data.guest ?? interviewBySlug[s].data.outlet}
                  </a>
                ))}
              </div>
            )}

            <div class="prose prose-sm max-w-none" style="font-family:var(--font-serif);font-size:15px;color:rgba(11,31,38,0.65);">
              <Content />
            </div>
          </div>

          <div style="text-align:right;padding-top:4px;">
            <div style={`display:inline-block;padding:4px 10px;background:${pillBg};color:${pillCol};font-family:var(--font-mono);font-size:9px;letter-spacing:0.15em;text-transform:uppercase;font-weight:600;`}>
              {theme.data.priority}
            </div>
          </div>
        </div>
      );
    })}
  </div>

  <div class="mt-12 pt-10" style="border-top:1px solid var(--border-ink);">
    <p class="type-body-small" style="color:var(--mute);">
      Add question themes in <code style="font-family:var(--font-mono);font-size:12px;background:var(--bone-2);padding:1px 4px;">src/content/open-questions/slug.md</code>.
      Add interviews in <code style="font-family:var(--font-mono);font-size:12px;background:var(--bone-2);padding:1px 4px;">src/content/interviews/slug.md</code>.
    </p>
  </div>
</Section>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.dq-pill');
  const blocks     = document.querySelectorAll<HTMLElement>('.dq-block');
  const toggleBtn  = document.getElementById('dq-toggle-asked') as HTMLButtonElement;
  let hideAsked    = false;
  let activeFilter = 'all';

  function applyFilters() {
    blocks.forEach(el => {
      const matchPriority = activeFilter === 'all' || el.dataset.priority === activeFilter;
      const matchAsked    = !hideAsked || el.dataset.asked !== 'true';
      el.style.display    = matchPriority && matchAsked ? '' : 'none';
    });
  }

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      activeFilter = btn.dataset.filter ?? 'all';
      filterBtns.forEach(b => {
        const isActive = b === btn;
        b.style.background = isActive ? 'var(--ink)' : 'transparent';
        b.style.color      = isActive ? 'var(--bone)' : 'var(--mute)';
        b.style.border     = isActive ? 'none' : '1px solid var(--border-ink)';
      });
      applyFilters();
    });
  });

  toggleBtn?.addEventListener('click', () => {
    hideAsked = !hideAsked;
    toggleBtn.textContent = hideAsked ? 'Show already-asked' : 'Hide already-asked';
    applyFilters();
  });
</script>
